{
  "name": "tiktok-inline-telegram-bot",
  "version": "1.0.0",
  "private": true,
  "description": "Inline Telegram bot that parses and sends TikTok videos",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "xvfb": "xvfb-run -a --server-args='-screen 0 1920x1080x24' node dist/index.js"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "puppeteer": "^24.0.0",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.23.0",
    "typescript": "^5.7.0"
  }
}
