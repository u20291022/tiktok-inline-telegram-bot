BOT_TOKEN=your-telegram-bot-token
# polling (local development, default) | webhook (production behind nginx)
BOT_MODE=polling
WEBHOOK_DOMAIN=https://example.com
WEBHOOK_PATH=/tg-webhook-path
WEBHOOK_PORT=443
# Enables verbose per-step timing logs for diagnosing slow TikTok parses (default off)
DEBUG_TIMING=false
